# YouTube Clipper 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# FFmpeg 配置
# ============================================================================

# FFmpeg 可执行文件路径（可选，留空则自动检测）
# macOS (Apple Silicon): /opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# macOS (Intel): /usr/local/opt/ffmpeg-full/bin/ffmpeg
# Linux: /usr/bin/ffmpeg
FFMPEG_PATH=

# 字幕烧录样式
SUBTITLE_FONT_SIZE=24
SUBTITLE_MARGIN_V=30

# 双语字幕配色（仅对 SRT 双语字幕生效）
# 开启后会自动生成 ASS 并使用不同颜色区分中英文
BILINGUAL_COLOR=true
# 英文在上: EN_FIRST / 中文在上: ZH_FIRST
BILINGUAL_ORDER=EN_FIRST
# 颜色格式: #RRGGBB
SUBTITLE_EN_COLOR=#FFD54F
SUBTITLE_ZH_COLOR=#FFFFFF
# 字体与描边（可选）
SUBTITLE_FONT_NAME=PingFang SC
SUBTITLE_OUTLINE=2
SUBTITLE_SHADOW=1
SUBTITLE_ALIGNMENT=2
# ASS 渲染参考分辨率
SUBTITLE_PLAYRESX=1920
SUBTITLE_PLAYRESY=1080

# ============================================================================
# 输出配置
# ============================================================================

# 输出目录（默认: 当前工作目录下的 youtube-clips/）
OUTPUT_DIR=./youtube-clips

# 视频质量限制（最高分辨率）
# 选项: 720, 1080, 1440, 2160 (4K)
MAX_VIDEO_HEIGHT=1080

# ============================================================================
# 字幕翻译配置
# ============================================================================

# 批量翻译大小（每批翻译的字幕条数）
# 推荐: 20-25
TRANSLATION_BATCH_SIZE=20

# 目标翻译语言
# 选项: 中文, 日语, 韩语, 西班牙语, 等
TARGET_LANGUAGE=中文

# ============================================================================
# 章节分析配置
# ============================================================================

# 目标章节时长（秒）
# 推荐: 180 (3分钟) - 300 (5分钟)
TARGET_CHAPTER_DURATION=180

# ============================================================================
# 学习型短片配置
# ============================================================================

# 学习型短片目标时长（秒）
LEARNING_CLIP_MIN_SEC=30
LEARNING_CLIP_MAX_SEC=60
LEARNING_CLIP_TARGET_SEC=45

# 字幕挖空占位符
MASK_TOKEN=____

# ----------------------------------------------------------------------------
# 引导卡片配置 (Intro Card)
# ----------------------------------------------------------------------------

# 引导卡片时长（秒）
INTRO_DURATION_SEC=4

# 引导卡片配色
INTRO_TITLE_COLOR=#7AD7FF
INTRO_SUBTITLE_COLOR=#FFFFFF
INTRO_BLANK_COLOR=#FFD54F

# ----------------------------------------------------------------------------
# 过渡卡片配置 (Transition Card)
# ----------------------------------------------------------------------------

# 过渡卡片时长（秒）
TRANSITION_DURATION_SEC=3

# 过渡卡片配色
TRANSITION_TITLE_COLOR=#7AD7FF
TRANSITION_SUBTITLE_COLOR=#FFFFFF

# ----------------------------------------------------------------------------
# Summary 卡片配置
# ----------------------------------------------------------------------------

# Summary 卡片时长（秒）
SUMMARY_DURATION_SEC=4

# Summary 是否包含中文释义
SUMMARY_INCLUDE_TRANSLATION=true

# Summary 配色（默认值可按需调整）
SUMMARY_TITLE_COLOR=#7AD7FF
SUMMARY_EN_COLOR=#FFD54F
SUMMARY_ZH_COLOR=#FFFFFF

# ============================================================================
# yt-dlp 配置
# ============================================================================

# yt-dlp 代理设置（如果需要）
# 格式: http://proxy-server:port 或 socks5://proxy-server:port
YT_DLP_PROXY=

# yt-dlp 下载速率限制（如果需要）
# 格式: 50K, 4.2M, 等
YT_DLP_RATE_LIMIT=

# ============================================================================
# 高级配置
# ============================================================================

# 临时文件目录（用于解决路径空格问题）
# 留空则使用系统默认临时目录
TEMP_DIR=

# 是否保留临时文件（调试用）
# 选项: true, false
KEEP_TEMP_FILES=false

# 日志级别
# 选项: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# 注意事项
# ============================================================================

# 1. 此文件中的配置是可选的，如果不设置，Skill 会使用默认值
# 2. 路径可以使用 ~ 表示用户主目录
# 3. 环境变量值不需要引号
# 4. 以 # 开头的行是注释
# 5. 修改配置后需要重启 Claude Code 才能生效
